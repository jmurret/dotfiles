#!/usr/bin/zsh
# Create a new git worktree in a sibling directory, start tmux session, and run bdloop

set -e

# Parse flags
split_mode=false
while [[ $1 == --* ]]; do
    case $1 in
        --split) split_mode=true; shift ;;
        *) echo "Error: Unknown option $1" >&2; exit 1 ;;
    esac
done

branch_name=$1
epic_id=$2

if [[ -z $branch_name ]]; then
    echo "Error: Branch name required" >&2
    echo "Usage: tmux-claude-worktree [--split] <branch-name> <epic-id>" >&2
    exit 1
fi

if [[ -z $epic_id ]]; then
    echo "Error: Epic ID required" >&2
    echo "Usage: tmux-claude-worktree [--split] <branch-name> <epic-id>" >&2
    exit 1
fi

# Find the git repository root
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
repo_name=$(basename "$repo_root")

# Navigate to parent directory where worktrees will be siblings
parent_dir=$(dirname "$repo_root")
worktree_dir="$parent_dir/$branch_name"

# Check if worktree directory already exists
if [[ -d "$worktree_dir" ]]; then
    echo "Error: Worktree directory already exists: $worktree_dir" >&2
    exit 1
fi

# Create the worktree with a new branch
echo "Creating git worktree at: $worktree_dir"
cd "$repo_root"
git worktree add -b "$branch_name" "$worktree_dir"

# Set up beads redirect to share issues with main repo
cd "$worktree_dir"
mkdir -p .beads
echo "../$repo_name/.beads" > .beads/redirect

# Create tmux session name from branch name (replace . with _)
session_name=$(echo "$branch_name" | tr . _)

claude_cmd="env -u CLAUDECODE claude --dangerously-skip-permissions '/bdloop $epic_id'"

if $split_mode; then
    # Split current window horizontally (side-by-side) with agent in new pane
    if [[ -z $TMUX ]]; then
        echo "Error: --split requires running inside a tmux session" >&2
        exit 1
    fi

    echo "Splitting pane for agent"
    pane_id=$(tmux split-window -h -c "$worktree_dir" -P -F '#{pane_id}')

    echo "Starting claude with /bdloop $epic_id"
    tmux send-keys -t "$pane_id" "$claude_cmd" C-m

    # Auto-accept the bypass permissions confirmation prompt
    sleep 5
    tmux send-keys -t "$pane_id" Down
    sleep 1
    tmux send-keys -t "$pane_id" Enter

    echo ""
    echo "✓ Worktree created: $worktree_dir"
    echo "✓ Branch created: $branch_name"
    echo "✓ Agent running in split pane: $pane_id"
else
    # Check if session already exists
    if tmux has-session -t="$session_name" 2>/dev/null; then
        echo "Error: tmux session '$session_name' already exists" >&2
        exit 1
    fi

    # Create new tmux session in detached mode
    echo "Creating tmux session: $session_name"
    tmux new-session -ds "$session_name" -c "$worktree_dir"

    echo "Starting claude with /bdloop $epic_id"
    tmux send-keys -t "$session_name" "$claude_cmd" C-m

    # Auto-accept the bypass permissions confirmation prompt
    sleep 5
    tmux send-keys -t "$session_name" Down
    sleep 1
    tmux send-keys -t "$session_name" Enter

    echo ""
    echo "✓ Worktree created: $worktree_dir"
    echo "✓ Branch created: $branch_name"
    echo "✓ tmux session started: $session_name"
    echo ""
    echo "To switch to the session: tmux switch-client -t $session_name"
    echo "To attach to the session: tmux attach -t $session_name"
fi
echo "To clean up when done: git worktree remove $worktree_dir && git branch -d $branch_name"
