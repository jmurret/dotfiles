#!/usr/bin/env bash
#
# pre-commit-sync-agents: Keep Claude and opencode agent config in sync.
#
# Installed by install.sh as .git/hooks/pre-commit.
#
# - Claude canonical files staged (only) -> forward sync  (Claude -> opencode)
# - opencode agents staged (only)        -> reverse sync  (opencode -> Claude)
# - Both staged                          -> forward sync wins; Claude is source of truth
#
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

staged=$(git diff --cached --name-only)
claude_doc_changed=$(grep -c "^\.config/claude/CLAUDE\.md$" <<< "$staged" || true)
claude_agents_changed=$(grep -c "^\.config/claude/agents/" <<< "$staged" || true)
opencode_changed=$(grep -c "^\.config/opencode/agents/" <<< "$staged" || true)
claude_changed=$((claude_doc_changed + claude_agents_changed))

if [ "$claude_changed" -eq 0 ] && [ "$opencode_changed" -eq 0 ]; then
  exit 0
fi

if [ "$claude_changed" -gt 0 ] && [ "$opencode_changed" -gt 0 ]; then
  echo "  [WARN] Both Claude and opencode agents staged — Claude is source of truth, forward syncing"
fi

if [ "$claude_changed" -gt 0 ]; then
  echo "  [ .. ] Claude agents changed — forward syncing to opencode"
  python3 "$DOTFILES_DIR/bin/sync-agent-config" || { echo "  [FAIL] sync-agent-config failed" >&2; exit 1; }
  git add "$DOTFILES_DIR/.config/opencode/agents/"
  git add "$DOTFILES_DIR/.config/opencode/AGENTS.md"
  echo "  [ OK ] opencode agents staged"
else
  echo "  [ .. ] opencode agents changed — reverse syncing to Claude"
  python3 "$DOTFILES_DIR/bin/sync-agent-config" --from-opencode || { echo "  [FAIL] sync-agent-config --from-opencode failed" >&2; exit 1; }
  git add "$DOTFILES_DIR/.config/claude/agents/"
  echo "  [ OK ] Claude agents staged"
fi
